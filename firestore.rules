// Firestore Security Rules for Computer Skills Academy
// Copy-paste these into Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Explicitly allowed student IDs
    function isValidStudentId(studentId) {
      return studentId == "st_1" || studentId == "st_2";
    }

    // Exact email required for each student — no wildcards
    function requiredEmail(studentId) {
      return studentId == "st_1"
        ? "student1@learnpc.app"
        : "student2@learnpc.app";
    }

    // The authenticated user must own this exact student record
    function isOwner(studentId) {
      return request.auth != null
        && isValidStudentId(studentId)
        && request.auth.token.email == requiredEmail(studentId);
    }

    // Allow all access (development mode — tighten for production)
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
