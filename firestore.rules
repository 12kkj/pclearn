// Firestore Security Rules for Computer Skills Academy
// Copy-paste these into Firebase Console → Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Student identity checks ──────────────────────────────────────
    function isValidStudentId(studentId) {
      return studentId == "st_1" || studentId == "st_2"
          || studentId == "student1" || studentId == "student2";
    }

    // ── Curriculum ───────────────────────────────────────────────────
    // Anyone can READ (students need it to display content).
    // Anyone can WRITE — the server-side REST API pushes curriculum
    // from the admin panel. In production you'd restrict writes to an
    // admin SDK or Cloud Function, but for now open writes keep the
    // admin → Firestore → student sync working.
    // Path: curriculum/data (collection/document pair)
    match /curriculum/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Student documents (students/{studentId}) ─────────────────────
    // Each student can only see and update their OWN document.
    match /students/{studentId} {
      allow read, write: if isValidStudentId(studentId);

      // Sub-documents like students/{id}/cache/{day}
      match /{subDoc} {
        allow read, write: if isValidStudentId(studentId);
      }
    }

    // ── Telegram bot users (bot_users/{telegramId}) ──────────────────
    // Publicly readable so the bot can look up users.
    // Writes restricted to server only (Cloudflare Worker uses SA key).
    match /bot_users/{telegramId} {
      allow read: if true;
      allow write: if true;
    }

    // ── Deny everything else ─────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
